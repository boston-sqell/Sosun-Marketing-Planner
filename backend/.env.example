PORT=5000
SPREADSHEET_ID=1P8d6WWEmSNLLkdu8kMzPQuBq_nbboVaHIP7-JUYwNpg

# Google Service Account for Google Sheets Sync AND Google Drive (Media Library).
# The SAME service account is used for both. Enable the Google Drive API on the
# project and share the "Marketing Hub" root folder with this email as Editor.
# Note: the app requests the Drive scope at runtime; no extra env var is needed.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Admin Service Account (JSON string fallback for local dev)
# Alternatively, set GOOGLE_APPLICATION_CREDENTIALS path in environment variables
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", "project_id": "..."}'

# REQUIRED: Secret used to sign short-lived media-streaming tokens (thumbnails/preview/download).
# The server will refuse to start if this is not set. Use a long, random value — e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Do NOT reuse GOOGLE_PRIVATE_KEY here. This must be an independent secret.
MEDIA_TOKEN_SECRET=change-me-to-a-long-random-string

# Shared secret for the scheduled-sync endpoint (POST /api/drive/sync/cron).
# A Cloud Scheduler job must send this as the "X-Cron-Secret" header. If unset,
# the cron endpoint is effectively disabled (manual "Sync" still works).
CRON_SECRET=change-me-to-a-long-random-string

# Web Push Notifications — VAPID keys.
# Generate once:  npx web-push generate-vapid-keys
# If not set, push notifications are disabled (the server still starts).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:push@sosunmarketingplanner.online
