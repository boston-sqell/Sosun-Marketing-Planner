rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to get active user role
    function getRole() {
      return request.auth.token.role;
    }

    // Authenticated users check
    function isAuth() {
      return request.auth != null;
    }

    // Users Collection
    match /users/{userId} {
      // Restrict directory reads to staff; everyone else may read only their own
      // profile. Stops any authenticated user from enumerating all emails/roles.
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        getRole() == 'admin' ||
        getRole() == 'internal'
      );
      // A user may write their own profile, but an UPDATE may never change the
      // `role` claim NOR the `plannerRole` capability field (both are authz
      // fields managed by the backend; only an admin may change them —
      // otherwise a user could self-grant planner permissions). Admins may
      // write any user doc.
      allow write: if isAuth() && (
        getRole() == 'admin' ||
        (request.auth.uid == userId && (
          resource == null ||
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'plannerRole'])
        ))
      );
    }

    // Campaigns Collection
    match /campaigns/{campaignId} {
      // Direct reads blocked for agency/external_agency to enforce field stripping server-side
      allow read: if isAuth() && getRole() != 'agency' && getRole() != 'external_agency';
      // Admin and Internal can write/create; Agency cannot delete/create campaigns
      allow create, update: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow delete: if isAuth() && getRole() == 'admin';
    }

    // Tasks Collection
    match /tasks/{taskId} {
      // Direct reads blocked for agency/external_agency to enforce comment stripping (internalOnly comments)
      allow read: if isAuth() && getRole() != 'agency' && getRole() != 'external_agency';
      // Admin and Internal can create/delete tasks
      allow create, delete: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      // Direct client updates are restricted to staff. Agency status/checklist
      // changes go through the backend API (Admin SDK), which enforces the
      // condition-aware RBAC and whitelists the writable fields. Allowing agency
      // direct doc writes here would bypass all of that (mass-assignment).
      allow update: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
    }

    // Assets Collection (legacy Firebase Storage file manager)
    match /assets/{assetId} {
      allow read: if isAuth();
      allow create: if isAuth();
      // Legacy collection has no owner UID — only a display name, which users can
      // set on their own profile and thus spoof. Restrict delete to staff.
      allow delete: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
    }

    // Media Assets (Google Drive DAM index).
    // Writes go exclusively through the backend (Admin SDK bypasses these rules),
    // so clients are read-only here. This keeps the Drive workspace boundary and
    // metadata integrity enforced server-side.
    match /mediaAssets/{assetId} {
      allow read: if isAuth();
      allow write: if false;

      // Approval history / comments — backend-managed, client read-only.
      match /activity/{entryId} {
        allow read: if isAuth();
        allow write: if false;
      }
    }

    // Application settings (workspace config, etc.). Backend-managed.
    match /settings/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Global Activities Collection — append-only audit log. Any authed user may
    // add an entry; nobody may edit or delete one from the client (prevents
    // tampering). Backend (Admin SDK) bypasses these rules for housekeeping.
    match /activities/{activityId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Brand portfolio (first-class brand records)
    match /brands/{brandId} {
      allow read: if isAuth();
      allow write: if isAuth() && getRole() == 'admin';
    }

    // Events & sponsorships (trade shows, exhibitions, activations)
    match /events/{eventId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow delete: if isAuth() && getRole() == 'admin';

      // Real-time packing board
      match /packingItems/{itemId} {
        allow read: if isAuth();
        allow write: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      }

      // Logistics legs (shipments, booth, staffing, permits)
      match /logistics/{legId} {
        allow read: if isAuth();
        allow write: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      }
    }

    // Retail outlets
    match /outlets/{outletId} {
      allow read: if isAuth();
      allow write: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
    }

    // Display asset distributions at outlets
    match /distributions/{distId} {
      allow read: if isAuth();
      allow write: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
    }

    // Budget ledger — agency partners cannot see spend
    match /budgetEntries/{entryId} {
      allow read: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow create, update: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow delete: if isAuth() && getRole() == 'admin';
    }

    // Generated monthly brand reports — created by backend (Admin SDK bypasses rules);
    // admins may delete stale or incorrect reports from the client.
    match /reports/{reportId} {
      allow read: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow create, update: if false;
      allow delete: if isAuth() && getRole() == 'admin';
    }

    // News Sentinel — monitored feeds, admin-managed from the News settings tab.
    match /newsSources/{sourceId} {
      allow read: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow write: if isAuth() && getRole() == 'admin';
    }

    // News Sentinel — brand watch-terms, admin-managed.
    match /newsKeywords/{keywordId} {
      allow read: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow write: if isAuth() && getRole() == 'admin';
    }

    // Detected mentions — created exclusively by the backend scan worker
    // (Admin SDK bypasses rules). Internal/admin may update status (review,
    // promote, dismiss); no client create/delete.
    match /newsMentions/{mentionId} {
      allow read:   if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow update: if isAuth() && (getRole() == 'admin' || getRole() == 'internal');
      allow create, delete: if false;
    }

    // Push notification subscriptions — each user manages their own.
    // Backend (Admin SDK) reads all subscriptions for broadcast delivery.
    match /pushSubscriptions/{subId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // ── Marketing Planner ────────────────────────────────────────────────────
    // All planner access is server-mediated through the Admin SDK (Admin SDK
    // bypasses these rules). Client writes are denied everywhere; the workflow
    // engine, permission checks and audit writes all run server-side. See
    // docs/planner/spec-revisions.md §14.4.

    // Work items — staff may read directly; agency/external_agency go through
    // the API (which applies planner-role scoping and field stripping). No
    // client writes: status changes ONLY via the transition endpoint.
    match /workItems/{itemId} {
      allow read: if isAuth() && getRole() != 'agency' && getRole() != 'external_agency';
      allow write: if false;

      // Immutable audit trail (spec §11) — written exclusively by the Admin SDK
      // inside the transition transaction. Never client-writable.
      match /activity/{entryId} {
        allow read: if isAuth() && getRole() != 'agency' && getRole() != 'external_agency';
        allow write: if false;
      }

      // Storage-backed attachment index (created via the API).
      match /attachments/{attId} {
        allow read: if isAuth() && getRole() != 'agency' && getRole() != 'external_agency';
        allow write: if false;
      }

      // Threaded comments (created via the API, which strips internal-only).
      match /comments/{commentId} {
        allow read: if isAuth() && getRole() != 'agency' && getRole() != 'external_agency';
        allow write: if false;
      }
    }

    // Engine config — readable by any authenticated staff member so the UI can
    // render workflows/types/fields; only the backend (Admin SDK) writes it.
    match /workflows/{workflowId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /workItemTypes/{typeId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /customFields/{fieldId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /plannerConfig/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Transactional outbox — internal machinery, written in-transaction and
    // drained by the backend (Admin SDK). No client access whatsoever.
    match /plannerOutbox/{jobId} {
      allow read, write: if false;
    }
  }
}
